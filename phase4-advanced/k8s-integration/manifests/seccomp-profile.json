        "close",
        "mmap",
        "munmap",
        "mprotect",
        "brk",
        "poll",
        "getsockopt",
        "sendto",
        "recvmsg",
        "connect",
        "socket",
        "sched_setaffinity",
        "rt_sigaction",
        "rt_sigprocmask",
        "sigaltstack",
        "exit_group",
        "futex",
        "getrandom",
        "writev"
      ],
      "action": "SCMP_ACT_ALLOW"
    }
  ]
}
